# RagBench environment configuration
# Copy to .env and fill in your values

# LLM provider: "ollama" (local, free) or "openai" (API cost)
RAGBENCH_LLM_PROVIDER=ollama
RAGBENCH_OLLAMA_MODEL=mistral
RAGBENCH_OLLAMA_BASE_URL=http://localhost:11434

# Uncomment for OpenAI
# RAGBENCH_LLM_PROVIDER=openai
# RAGBENCH_OPENAI_API_KEY=sk-...
# RAGBENCH_OPENAI_MODEL=gpt-4o-mini

# Embedding model (runs locally regardless of LLM choice)
RAGBENCH_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking: "fixed" | "sentence" | "semantic"
RAGBENCH_CHUNK_STRATEGY=sentence
RAGBENCH_CHUNK_SIZE=512
RAGBENCH_CHUNK_OVERLAP=64

# Retrieval
RAGBENCH_TOP_K=5
RAGBENCH_RETRIEVAL_TOP_K=20
RAGBENCH_SIMILARITY_THRESHOLD=0.3

# Reranker (cross-encoder for two-stage retrieval)
RAGBENCH_USE_RERANKER=true
RAGBENCH_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAGBENCH_RERANKER_THRESHOLD=-2.0
